# Lead notification email
LEAD_EMAIL=kontakt@kasoria.com

# SMTP (optional — only needed if you want email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
SMTP_FROM=check@kasoria.com

# PostHog analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_yourkey
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Meta Pixel + Conversions API
# Pixel ID: Events Manager → your dataset → Settings → "Dataset ID"
# Access token: Events Manager → Conversions API → "Generate access token"
NEXT_PUBLIC_META_PIXEL_ID=YOUR_PIXEL_ID_HERE
META_CAPI_ACCESS_TOKEN=YOUR_CAPI_TOKEN_HERE
# Optional: set while validating in Events Manager → Test events tab, remove in production
META_TEST_EVENT_CODE=
